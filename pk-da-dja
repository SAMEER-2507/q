import matplotlib.pyplot as plt

aer_sim = AerSimulator()
print("Imports successful!")


def oracle_constant_0():
    qc = QuantumCircuit(2)
    qc.name = "f1: Constant-0"
    return qc

def oracle_constant_1():
    qc = QuantumCircuit(2)
    qc.x(1)
    qc.name = "f2: Constant-1"
    return qc

def oracle_balanced_identity():
    qc = QuantumCircuit(2)
    qc.cx(0, 1)
    qc.name = "f3: Balanced-Identity"
    return qc

def oracle_balanced_negation():
    qc = QuantumCircuit(2)
    qc.x(0)
    qc.cx(0, 1)
    qc.x(0)
    qc.name = "f4: Balanced-Negation"
    return qc

all_oracles = [
    (oracle_constant_0(), "Constant"),
    (oracle_constant_1(), "Constant"),
    (oracle_balanced_identity(), "Balanced"),
    (oracle_balanced_negation(), "Balanced"),
]

# Draw all four oracles
fig, axes = plt.subplots(1, 4, figsize=(14, 2))
for ax, (oracle, _) in zip(axes, all_oracles):
    oracle.draw('mpl', ax=ax)
    ax.set_title(oracle.name, fontsize=8)
plt.suptitle("All Four Oracle Circuits", fontsize=12, y=1.05)
plt.tight_layout()
plt.show()


def deutsch_circuit(oracle):
    dj = QuantumCircuit(2, 1)

    # Step 1: Prepare q1 = |1>
    dj.x(1)
    dj.barrier(label="Init")

    # Step 2: Hadamard on both qubits  ->  q0=|+>, q1=|->
    dj.h(0)
    dj.h(1)
    dj.barrier(label="H gates")

    # Step 3: Apply oracle
    dj = dj.compose(oracle)
    dj.barrier(label="Oracle")

    # Step 4: Hadamard on input qubit q0
    dj.h(0)
    dj.barrier(label="Measure")

    # Step 5: Measure q0 only
    dj.measure(0, 0)

    return dj

print("deutsch_circuit() defined.")


shots = 1024
results_all = {}

for oracle, true_type in all_oracles:
    circuit = deutsch_circuit(oracle)
    t_qc = transpile(circuit, aer_sim)
    counts = aer_sim.run(t_qc, shots=shots).result().get_counts()
    measured = list(counts.keys())[0]
    verdict = "CONSTANT" if measured == '0' else "BALANCED"
    correct = "✓" if verdict == true_type else "✗"
    results_all[oracle.name] = counts
    print(f"{oracle.name:<28}  Measured: '{measured}'  →  {verdict:<10}  {correct}")

print("\nDecision Rule: measure '0' → CONSTANT  |  measure '1' → BALANCED")


for oracle, _ in all_oracles:
    circuit = deutsch_circuit(oracle)
    print(f"\nDeutsch Circuit — {oracle.name}:")
