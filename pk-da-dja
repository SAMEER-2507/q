# Classical approach: must evaluate f(0) AND f(1) — 2 queries
def classical_deutsch(f):
    """
    Classical solution: evaluate f at both inputs.
    Requires 2 oracle queries.
    """
    f0, f1 = f(0), f(1)
    oracle_calls = 2
    result = "CONSTANT" if f0 == f1 else "BALANCED"
    return result, oracle_calls, f0, f1

# Define the four functions classically
