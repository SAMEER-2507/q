import numpy as np
import matplotlib.pyplot as plt
from qiskit import QuantumCircuit, transpile
from qiskit.visualization import plot_histogram, array_to_latex
from qiskit.quantum_info import Statevector
from qiskit_aer import AerSimulator

# n = number of input qubits (total circuit has n+1 qubits)
n = 3
sim = AerSimulator()

print(f"Deutsch-Jozsa for n = {n} input qubits")
print("Imports successful!")


def make_constant_oracle(n, output=None):
    if output is None:
        output = np.random.randint(2)

    oracle = QuantumCircuit(n + 1)
    if output == 1:
        oracle.x(n)

    oracle.name = f"Const-{output}"
    return oracle, output


!pip install pylatexenc

const_oracle, const_output = make_constant_oracle(n)
print(f"Constant Oracle — fixed output = {const_output}")
const_oracle.draw('mpl')


def make_balanced_oracle(n, b_str=None):
    if b_str is None:
        b_str = ''.join([str(np.random.randint(2)) for _ in range(n)])
        if b_str == '0' * n:
            b_str = '1' * n

    oracle = QuantumCircuit(n + 1)

    # Step 1: X-gates where b_str[i] == '1'
    for i in range(len(b_str)):
        if b_str[i] == '1':
            oracle.x(i)
    oracle.barrier()

    # Step 2: CNOT from each input to output
    for i in range(n):
        oracle.cx(i, n)
    oracle.barrier()

    # Step 3: Undo X-gates
    for i in range(len(b_str)):
        if b_str[i] == '1':
            oracle.x(i)

    oracle.name = f"Balanced(b={b_str})"
    return oracle, b_str


bal_oracle, b_str = make_balanced_oracle(n, b_str='101')
print(f"Balanced Oracle — secret string b = '{b_str}'")
bal_oracle.draw('mpl')


def deutsch_jozsa_circuit(n, oracle):
    dj = QuantumCircuit(n + 1, n)

    # Step 1: H on all input qubits
    for q in range(n):
        dj.h(q)

    # Step 2: Output qubit into |->
    dj.x(n)
    dj.h(n)
    dj.barrier(label='Init')

    # Step 3: Oracle
    dj = dj.compose(oracle)
    dj.barrier(label='Oracle')

    # Step 4: H on input qubits again
    for q in range(n):
        dj.h(q)
    dj.barrier(label='Final H')

    # Step 5: Measure input register
    for i in range(n):
        dj.measure(i, i)

    return dj


print("deutsch_jozsa_circuit() defined.")


dj_const = deutsch_jozsa_circuit(n, const_oracle)
print(f"DJ Circuit — Constant Oracle (output={const_output}):")
dj_const.draw('mpl')


shots = 1024
t_qc = transpile(dj_const, sim)
counts_const = sim.run(t_qc, shots=shots).result().get_counts()

verdict = 'CONSTANT' if all(k == '0' * n for k in counts_const) else 'BALANCED'
print(f"Counts  : {counts_const}")
print(f"Verdict : {verdict}  (expected: CONSTANT)")

assert counts_const.get('0' * n, 0) == shots, "Expected 100% |000>!"
print("Assertion passed.")

plot_histogram(counts_const, title=f"Constant Oracle (output={const_output}) — all |{'0' * n}>")


dj_bal = deutsch_jozsa_circuit(n, bal_oracle)
print(f"DJ Circuit — Balanced Oracle (b='{b_str}'):")
dj_bal.draw('mpl')


t_qc = transpile(dj_bal, sim)
counts_bal = sim.run(t_qc, shots=shots).result().get_counts()

verdict = 'CONSTANT' if all(k == '0' * n for k in counts_bal) else 'BALANCED'
print(f"Counts  : {counts_bal}")
print(f"Verdict : {verdict}  (expected: BALANCED)")

assert counts_bal.get('0' * n, 0) == 0, "Expected 0% |000>!"
print("Assertion passed.")

plot_histogram(counts_bal, title=f"Balanced Oracle (b='{b_str}') — no |{'0' * n}>")


fig, axes = plt.subplots(1, 2, figsize=(12, 4))
plot_histogram(counts_const, ax=axes[0],
               title=f"Constant (output={const_output}) — all |{'0' * n}>")
plot_histogram(counts_bal, ax=axes[1],
               title=f"Balanced (b='{b_str}') — no |{'0' * n}>")
plt.suptitle("Deutsch-Jozsa Algorithm — Ideal Simulator", fontsize=14, y=1.02)
plt.tight_layout()
plt.show()


all_b = [format(i, f'0{n}b') for i in range(1, 2**n)]

print(f"Testing all {len(all_b)} non-trivial balanced oracles for n={n}:")
print(f"{'b_str':<8} {'Counts':<35} {'Verdict':<10} Pass?")
print("-" * 65)

for b in all_b:
    oracle, _ = make_balanced_oracle(n, b_str=b)
    dj = deutsch_jozsa_circuit(n, oracle)
    counts = sim.run(transpile(dj, sim), shots=512).result().get_counts()
    verdict = 'CONSTANT' if all(k == '0' * n for k in counts) else 'BALANCED'
    passed = 'PASS' if verdict == 'BALANCED' else 'FAIL'
    print(f"{b:<8} {str(counts):<35} {verdict:<10} {passed}")


print(f"{'n':<4} {'Oracle':<10} {'Verdict':<10} {'Quantum queries':<17} {'Classical worst case'}")
print("-" * 70)

for test_n in [1, 2, 3, 4, 5]:
    for otype in ['constant', 'balanced']:
        if otype == 'constant':
            oracle, _ = make_constant_oracle(test_n, output=np.random.randint(2))
        else:
            oracle, _ = make_balanced_oracle(test_n)

        dj = deutsch_jozsa_circuit(test_n, oracle)
        counts = sim.run(transpile(dj, sim), shots=256).result().get_counts()
        verdict = 'CONSTANT' if all(k == '0' * test_n for k in counts) else 'BALANCED'
        print(f"{test_n:<4} {otype:<10} {verdict:<10} {'1':<17} {2**(test_n - 1) + 1}")

print("\nQuantum always uses exactly 1 query regardless of n!")


from qiskit_aer.noise import NoiseModel, depolarizing_error

noise_model = NoiseModel()
noise_model.add_all_qubit_quantum_error(depolarizing_error(0.01, 1), ['h', 'x'])
noise_model.add_all_qubit_quantum_error(depolarizing_error(0.02, 2), ['cx'])

noisy_sim = AerSimulator(noise_model=noise_model)
n_const = sim.run(transpile(dj_const, noisy_sim), shots=shots).result().get_counts()
n_bal = sim.run(transpile(dj_bal, noisy_sim), shots=shots).result().get_counts()

fig, axes = plt.subplots(1, 2, figsize=(12, 4))
plot_histogram(n_const, ax=axes[0], title=f"Noisy — Constant (output={const_output})")
plot_histogram(n_bal, ax=axes[1], title=f"Noisy — Balanced (b='{b_str}')")
plt.suptitle("Deutsch-Jozsa — Noisy Simulation (1% 1Q / 2% 2Q errors)", fontsize=13, y=1.02)
plt.tight_layout()
plt.show()

print(f"Noisy constant: non-|{'0' * n}> leakage = {sum(v for k, v in n_const.items() if k != '0' * n)} / {shots}")
print(f"Noisy balanced: spurious |{'0' * n}> count = {n_bal.get('0' * n, 0)} / {shots}")


