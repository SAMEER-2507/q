from qiskit import QuantumCircuit
from qiskit_aer import AerSimulator
from qiskit.visualization import plot_histogram
import matplotlib.pyplot as plt
import random

# Create quantum circuit (1 qubit, 1 classical bit)
qc = QuantumCircuit(1, 1)

# Apply Hadamard gate (creates superposition → fair coin)
qc.h(0)

# Measure qubit
qc.measure(0, 0)

# Simulator
sim = AerSimulator()

# Run experiment
job = sim.run(qc, shots=1000)
result = job.result()

# Get results
q_counts = result.get_counts()

print("Quantum Coin Results:", q_counts)

# Plot
plot_histogram(q_counts)
plt.show()

# Classical simulation
flips = 1000
results = [random.randint(0, 1) for _ in range(flips)]

heads = results.count(0)
tails = results.count(1)

c_counts = {'0': heads, '1': tails}

print("Classical Coin Results:", c_counts)

# Plot
plot_histogram(c_counts)
plt.show()

print("\n--- Comparison ---")

print("Quantum distribution:", q_counts)
print("Classical distribution:", c_counts)

# Calculate probabilities
q_prob_0 = q_counts.get('0', 0) / 1000
q_prob_1 = q_counts.get('1', 0) / 1000

c_prob_0 = c_counts['0'] / 1000
c_prob_1 = c_counts['1'] / 1000

print("\nQuantum Probabilities -> 0:", q_prob_0, " 1:", q_prob_1)
print("Classical Probabilities -> 0:", c_prob_0, " 1:", c_prob_1)
