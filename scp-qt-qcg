from qiskit import QuantumCircuit, transpile
from qiskit.visualization import plot_histogram

# Modern Aer simulator (imported from qiskit_aer)
from qiskit_aer import AerSimulator

print("Imports successful!")

def create_bell_pair():
    """
    Creates a Bell pair (maximally entangled state).
    Qubit 0 goes to Bob, Qubit 1 goes to Alice.

    Returns:
        QuantumCircuit: 2-qubit circuit prepared in a Bell state
    """
    qc = QuantumCircuit(2)
    qc.h(1)      # Hadamard on qubit 1 (Alice's qubit)
    qc.cx(1, 0)  # CNOT: control=1, target=0
    return qc

# Visualize the Bell pair circuit
bell = create_bell_pair()
print("Bell Pair Circuit:")
bell.draw('mpl')

def encode_message(qc, qubit, msg):
    """
    Encodes a 2-bit classical message using the superdense coding protocol.

    Args:
        qc    (QuantumCircuit): The circuit to encode the message on
        qubit (int)           : Index of Alice's qubit
        msg   (str)           : 2-bit binary string, e.g. '00', '01', '10', '11'

    Returns:
        QuantumCircuit: Circuit with encoding gates applied

    Raises:
        ValueError: If msg is not a valid 2-bit binary string
    """
    if len(msg) != 2 or not set(msg).issubset({'0', '1'}):
        raise ValueError(
            f"Invalid message '{msg}'. Must be a 2-bit binary string (e.g. '00', '01', '10', '11')."
        )

    if msg[1] == '1':   # Encode second bit with X
        qc.x(qubit)
    if msg[0] == '1':   # Encode first bit with Z
        qc.z(qubit)

    return qc

print("encode_message() defined.")

def decode_message(qc):
    """
    Bob decodes the message by reversing the Bell pair entanglement.

    Args:
        qc (QuantumCircuit): Circuit after Alice's encoding

    Returns:
        QuantumCircuit: Circuit with decoding gates applied
    """
    qc.cx(1, 0)  # CNOT: control=1 (Alice), target=0 (Bob)
    qc.h(1)      # Hadamard on Alice's qubit
    return qc

print("decode_message() defined.")

# Choose the message Alice wants to send
message = '10'   # Try: '00', '01', '10', '11'

# Step 1: Charlie creates the Bell pair
#   Qubit 0 -> Bob  |  Qubit 1 -> Alice
qc = create_bell_pair()
qc.barrier(label='Charlie\ncreates pair')

# Step 2: Alice encodes her 2-bit message onto qubit 1
qc = encode_message(qc, 1, message)
qc.barrier(label='Alice\nencodes')

# Step 3: Bob decodes after receiving Alice's qubit
qc = decode_message(qc)
qc.barrier(label='Bob\ndecodes')

# Step 4: Bob measures both qubits
qc.measure_all()

print(f"Message to send: '{message}'")
print("\nFull Superdense Coding Circuit:")
qc.draw('mpl')

shots = 1024

# Initialise the noiseless Aer simulator
sim = AerSimulator()

# Transpile and run
compiled_qc = transpile(qc, sim)
result = sim.run(compiled_qc, shots=shots).result()
counts = result.get_counts()

print(f"Measurement results : {counts}")
print(f"Expected message    : '{message}'")
print(f"Measured message    : '{max(counts, key=counts.get)}'")

plot_histogram(counts, title=f"Ideal Simulator — Message: '{message}'")

from qiskit_aer.noise import NoiseModel, depolarizing_error

# Build a simple depolarizing noise model
noise_model = NoiseModel()

# 1% error on single-qubit gates
error_1q = depolarizing_error(0.01, 1)
noise_model.add_all_qubit_quantum_error(error_1q, ['h', 'x', 'z'])

# 3% error on two-qubit gates (CNOT)
error_2q = depolarizing_error(0.03, 2)
noise_model.add_all_qubit_quantum_error(error_2q, ['cx'])

# Run noisy simulation
noisy_sim = AerSimulator(noise_model=noise_model)
compiled_noisy = transpile(qc, noisy_sim)
noisy_result = noisy_sim.run(compiled_noisy, shots=shots).result()
noisy_counts = noisy_result.get_counts()

# Calculate accuracy
correct  = noisy_counts.get(message, 0)
accuracy = (correct / shots) * 100

print(f"Noisy measurement results : {noisy_counts}")
print(f"Accuracy for '{message}'  : {accuracy:.2f}%")

plot_histogram(
    noisy_counts,
    title=f"Noisy Simulator — Message: '{message}' | Accuracy: {accuracy:.1f}%"
)

import matplotlib.pyplot as plt

messages = ['00', '01', '10', '11']
all_counts = {}

for msg in messages:
    qc_test = create_bell_pair()
    qc_test.barrier()
    qc_test = encode_message(qc_test, 1, msg)
    qc_test.barrier()
    qc_test = decode_message(qc_test)
    qc_test.measure_all()

    compiled = transpile(qc_test, sim)
    res = sim.run(compiled, shots=shots).result()
    all_counts[msg] = res.get_counts()
    measured = max(res.get_counts(), key=res.get_counts().get)
    status = 'PASS' if measured == msg else 'FAIL'
    print(f"[{status}]  Sent: '{msg}'  |  Measured: '{measured}'")

# Plot all four results side by side
fig, axes = plt.subplots(1, 4, figsize=(14, 3))
for ax, msg in zip(axes, messages):
    plot_histogram(all_counts[msg], ax=ax, title=f"Msg: '{msg}'")
plt.suptitle("Superdense Coding — All Four Messages (Ideal Simulator)", fontsize=13, y=1.02)
plt.tight_layout()
plt.show()

