from qiskit.quantum_info import random_statevector, Statevector

# Modern Aer simulator
from qiskit_aer import AerSimulator

print("Imports successful!")

def create_bell_pair(qc, a, b):
    """
    Creates a Bell pair between qubits a and b.

    Args:
        qc (QuantumCircuit): Circuit to apply the Bell pair to
        a  (int)           : Qubit index for first qubit (goes to Alice)
        b  (int)           : Qubit index for second qubit (goes to Bob)
    """
    qc.h(a)     # Put qubit a into |+>
    qc.cx(a, b) # CNOT: control=a, target=b

# Preview the Bell pair circuit
preview = QuantumCircuit(2)
create_bell_pair(preview, 0, 1)
print("Bell Pair Circuit:")
preview.draw('mpl')

def alice_gates(qc, psi, a):
    """
    Alice's encoding step.

    Args:
        qc  (QuantumCircuit): Circuit to apply gates to
        psi (int)           : Index of qubit Alice wants to teleport
        a   (int)           : Index of Alice's half of Bell pair
    """
    qc.cx(psi, a) # CNOT: psi controls a
    qc.h(psi)     # Hadamard on psi

print("alice_gates() defined.")

def measure_and_send(qc, a, b):
    """
    Alice measures her two qubits and stores results in classical bits.

    Args:
        qc (QuantumCircuit): Circuit to apply measurement to
        a  (int)           : Index of Alice's psi qubit
        b  (int)           : Index of Alice's Bell pair qubit
    """
    qc.barrier()
    qc.measure(a, 0) # Measure q0 -> classical bit 0 (crz)
    qc.measure(b, 1) # Measure q1 -> classical bit 1 (crx)

print("measure_and_send() defined.")

def bob_gates(qc, qubit, crz, crx):
    """
    Bob applies classically-controlled correction gates to recover |psi>.
    Uses the modern if_test() context manager (Qiskit 1.x).

    Args:
        qc    (QuantumCircuit)   : Circuit to apply gates to
        qubit (int)              : Index of Bob's qubit (q2)
        crz   (ClassicalRegister): Classical register holding Alice's crz bit
        crx   (ClassicalRegister): Classical register holding Alice's crx bit
    """
    # Apply X if crx == 1
    with qc.if_test((crx, 1)):
        qc.x(qubit)
    # Apply Z if crz == 1
    with qc.if_test((crz, 1)):
        qc.z(qubit)

print("bob_gates() defined.")

# Registers
qr  = QuantumRegister(3, name="q")
crz = ClassicalRegister(1, name="crz")  # Alice's measurement of q0
crx = ClassicalRegister(1, name="crx")  # Alice's measurement of q1
teleportation_circuit = QuantumCircuit(qr, crz, crx)

## STEP 1 — Telamon creates Bell pair between q1 and q2
create_bell_pair(teleportation_circuit, 1, 2)
teleportation_circuit.barrier(label="Telamon\ncreates pair")

## STEP 2 — Alice applies her gates
alice_gates(teleportation_circuit, 0, 1)

## STEP 3 — Alice measures and sends classical bits
measure_and_send(teleportation_circuit, 0, 1)

## STEP 4 — Bob decodes using classical bits
teleportation_circuit.barrier(label="Bob\ndecodes")
bob_gates(teleportation_circuit, 2, crz, crx)

print("Full Teleportation Circuit:")
